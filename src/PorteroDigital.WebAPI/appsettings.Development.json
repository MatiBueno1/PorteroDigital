{
  "Jwt": {
    "Issuer": "PorteroDigital.Dev",
    "Audience": "PorteroDigital.Mobile.Dev",
    "SigningKey": "{JWT_SIGNING_KEY}",
    "ExpirationMinutes": 480
  },
  "PushNotifications": {
    "Enabled": false,
    "AndroidChannelId": "visitors-dev",
    "AndroidSound": "default",
    "IosSound": "default"
  },
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=portero-digital.dev.db",
    "Sqlite": "Data Source=portero-digital.dev.db",
    "SqlServer": "Server=(localdb)\\mssqllocaldb;Database=PorteroDigitalDbDev;Trusted_Connection=True;TrustServerCertificate=True"
  },
  "Database": {
    "Provider": "Sqlite"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information"
    }
  },
  "Camera": {
    "RtspUrl": "{CAMERA_RTSP_URL}",
    "LightOnUrl": "{CAMERA_LIGHT_ON_URL}",
    "LightOffUrl": "{CAMERA_LIGHT_OFF_URL}",
    "NightVisionOnUrl": "{CAMERA_NIGHT_VISION_ON_URL}",
    "NightVisionOffUrl": "{CAMERA_NIGHT_VISION_OFF_URL}",
    "NightVisionAutoUrl": "{CAMERA_NIGHT_VISION_AUTO_URL}"
  }
}
